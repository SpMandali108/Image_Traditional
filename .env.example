# MongoDB connection URI (e.g. mongodb+srv://username:password@cluster.mongodb.net/dbname)
client=mongodb+srv://...

# Flask secret key for sessions
key=your_flask_secret_key

# Admin credentials for managing cycles and overrides
ADMIN_ID=admin_username
ADMIN_PASS=admin_password

# Port number for Flask app (default 5001 or 5500)
PORT=5500
